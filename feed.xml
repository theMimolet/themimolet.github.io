---
layout: null
---
<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/">
    <channel>
        <title>Mimolet's Blog</title>
        <link>{{ site.url }}/</link>
        <atom:link href="{{ site.url }}/feed.xml" rel="self" type="application/rss+xml"/>
        <description>Mimolet's blog, a place where I share my thoughts and experiences.</description>
        <language>en-us</language>
        <copyright>Copyright {{ site.time | date: '%Y' }} Mimolet. All rights reserved.</copyright>
        <lastBuildDate>{{ site.time | date: "%a, %d %b %Y %H:%M:%S %z" }}</lastBuildDate>
        <managingEditor>{{ site.email }} (Mimolet)</managingEditor>
        <webMaster>{{ site.email }} (Mimolet)</webMaster>
        <docs>https://www.rssboard.org/rss-specification</docs>
        <generator>Jekyll</generator>
        <category>News</category>
        <ttl>60</ttl>
        <image>
            <url>{{ site.url }}{{ site.images_path }}/favicon.ico</url>
            <title>Mimolet's Blog</title>
            <link>{{ site.url }}/</link>
            <width>32</width>
            <height>32</height>
        </image>
{% assign en_posts = site.posts | where: "lang", "en" | sort: "date" | reverse %}
{% for post in en_posts %}
{% assign asset_src_prefix = 'src="' | append: site.url | append: '/assets' %}
{% assign asset_href_prefix = 'href="' | append: site.url | append: '/assets' %}
{% assign post_html = post.content | replace: 'src="/assets', asset_src_prefix | replace: 'href="/assets', asset_href_prefix %}
        <item>
            <title>{{ post.title | xml_escape }}</title>
            <link>{{ site.url }}{{ post.url }}</link>
            <guid isPermaLink="true">{{ site.url }}{{ post.url }}</guid>
            <pubDate>{{ post.date | date: "%a, %d %b %Y %H:%M:%S %z" }}</pubDate>
            <description>{{ post.summary | default: post.excerpt | strip_html | normalize_whitespace | xml_escape }}</description>
            <content:encoded><![CDATA[{{ post_html }}]]></content:encoded>
        </item>
{% endfor %}
    </channel>
</rss>